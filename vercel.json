{
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/feed.xml",
      "destination": "https://oazbnyqqzezzjxaztdzr.supabase.co/functions/v1/feed"
    },
    {
      "source": "/:slug.html",
      "destination": "https://oazbnyqqzezzjxaztdzr.supabase.co/functions/v1/post?slug=:slug"
    }
  ]
}
